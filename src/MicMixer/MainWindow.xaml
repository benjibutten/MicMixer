        <!-- Play icon -->
        <Geometry x:Key="PlayIcon">M8,5.14V19.14L19,12.14L8,5.14Z</Geometry>
        <!-- Stop icon -->
        <Geometry x:Key="StopIcon">M18,18H6V6H18V18Z</Geometry>
        <!-- Refresh icon -->
        <Geometry x:Key="RefreshIcon">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</Geometry>
        <!-- Status pulse / signal icon -->
        <Geometry x:Key="SignalIcon">M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6Z</Geometry>
        <!-- Link / info icon -->
        <Geometry x:Key="InfoIcon">M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z</Geometry>
        <!-- Check circle icon (routing active) -->
        <Geometry x:Key="CheckCircleIcon">M12,2C17.52,2 22,6.48 22,12C22,17.52 17.52,22 12,22C6.48,22 2,17.52 2,12C2,6.48 6.48,2 12,2M11,16.5L18,9.5L16.59,8.09L11,13.67L7.91,10.59L6.5,12L11,16.5Z</Geometry>
        <!-- Circle off icon (routing stopped) -->
        <Geometry x:Key="CircleOffIcon">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20Z</Geometry>
        <!-- Music note icon -->
        <Geometry x:Key="MusicIcon">M12,3V13.55A4,4 0 0,0 10,13A4,4 0 0,0 6,17A4,4 0 0,0 10,21A4,4 0 0,0 14,17V7H18V3H12Z</Geometry>
        <!-- Download icon -->
        <Geometry x:Key="DownloadIcon">M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z</Geometry>
        <!-- Folder icon -->
        <Geometry x:Key="FolderIcon">M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z</Geometry>
        <!-- Cog / settings icon (music folder options) -->
        <Geometry x:Key="CogIcon">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</Geometry>
        <!-- Skip previous icon -->
        <Geometry x:Key="SkipPrevIcon">M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z</Geometry>
        <!-- Skip next icon -->
        <Geometry x:Key="SkipNextIcon">M16,18H18V6H16M6,18L14.5,12L6,6V18Z</Geometry>
        <!-- Pause icon -->
        <Geometry x:Key="PauseIcon">M14,19H18V5H14M6,19H10V5H6V19Z</Geometry>
        <!-- Queue (playlist plus) icon -->
        <Geometry x:Key="QueueIcon">M2,16H10V14H2M18,14V10H16V14H12V16H16V20H18V16H22V14M2,12H14V10H2M2,8H14V6H2V8Z</Geometry>
        <!-- Headphones icon -->
        <Geometry x:Key="HeadphonesIcon">M12,1C7.03,1 3,5.03 3,10V17A3,3 0 0,0 6,20H9V12H5V10A7,7 0 0,1 12,3A7,7 0 0,1 19,10V12H15V20H18A3,3 0 0,0 21,17V10C21,5.03 16.97,1 12,1Z</Geometry>
        <!-- Search icon -->
        <Geometry x:Key="SearchIcon">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</Geometry>
        <!-- Close / clear icon -->
        <Geometry x:Key="CloseIcon">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</Geometry>
        <!-- Chevron up icon (queue chip) -->
        <Geometry x:Key="ChevronUpIcon">M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z</Geometry>
        <!-- Drag handle icon (two dot columns) -->
        <Geometry x:Key="DragHandleIcon">M9,3H11V5H9V3M13,3H15V5H13V3M9,8H11V10H9V8M13,8H15V10H13V8M9,13H11V15H9V13M13,13H15V15H13V13</Geometry>
        <!-- Play/pause combined glyph (media key transport in external mode) -->
        <Geometry x:Key="PlayPauseGlyph">M3,5V19L11,12M13,19H16V5H13M18,5V19H21V5</Geometry>
        <!-- Single-track icon: box with a "1" (play only this track, then stop) -->
        <Geometry x:Key="SingleTrackIcon">M14,17H12V9H10V7H14V17M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19Z</Geometry>
        <!-- Timed play icon: play triangle inside a dashed clock circle (delayed start) -->
        <Geometry x:Key="TimedPlayIcon">M13,2.05C18.05,2.55 22,6.82 22,12C22,17.18 18.05,21.45 13,21.95V19.93C16.95,19.44 20,16.08 20,12C20,7.92 16.95,4.56 13,4.07V2.05M11,2.05V4.07C9.43,4.27 8,4.89 6.77,5.82L5.36,4.36C7,3.11 8.87,2.3 11,2.05M4.36,5.36L5.82,6.77C4.89,8 4.27,9.43 4.07,11H2.05C2.3,8.87 3.11,7 4.36,5.36M2.05,13H4.07C4.27,14.57 4.89,16 5.82,17.23L4.36,18.64C3.11,17 2.3,15.13 2.05,13M6.77,18.18C8,19.11 9.43,19.73 11,19.93V21.95C8.87,21.7 7,20.89 5.36,19.64L6.77,18.18M16,12L10,16V8L16,12Z</Geometry>
        <!-- Speaker / secondary output icon -->
        <Geometry x:Key="SpeakerIcon">M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z</Geometry>
        <!-- Chain link icon (volume sync) -->
        <Geometry x:Key="LinkIcon">M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12M8,13H16V11H8V13M17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7Z</Geometry>

        <!-- Slim scrollbar: 8 px rounded thumb, no arrow buttons, transparent track.
             Implicit style, so every scrollbar in the window (routing column,
             playlist, queue, dropdowns) gets the same look. -->
        <Style x:Key="SlimScrollPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="SlimScrollThumb" TargetType="Thumb">
            <Border x:Name="ThumbBg" Background="#C9D2DD" CornerRadius="4"/>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbBg" Property="Background" Value="#A9B6C6"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="ThumbBg" Property="Background" Value="#8B9BAE"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <ControlTemplate x:Key="SlimScrollBarVertical" TargetType="ScrollBar">
            <Grid Background="Transparent">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SlimScrollPageButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SlimScrollPageButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Template="{StaticResource SlimScrollThumb}" Margin="1,0" MinHeight="24"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="SlimScrollBarHorizontal" TargetType="ScrollBar">
            <Grid Background="Transparent">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SlimScrollPageButton}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SlimScrollPageButton}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Template="{StaticResource SlimScrollThumb}" Margin="0,1" MinWidth="24"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template" Value="{StaticResource SlimScrollBarVertical}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Template" Value="{StaticResource SlimScrollBarHorizontal}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Segmented mode switch (music source) -->
        <Style x:Key="ModeSegment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5B6B7C"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="SegmentBg" Background="Transparent" CornerRadius="6" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#10233A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SegmentBg" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#10233A"/>
                                <Setter TargetName="SegmentBg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.12"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared icon style helper -->
        <Style x:Key="SectionIcon" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Info-tooltip helpers: (i) icon next to a section label with an explanatory tooltip -->
        <Style x:Key="InfoTipHost" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
        </Style>
        <Style x:Key="InfoTipIcon" TargetType="Path" BasedOn="{StaticResource SectionIcon}">
            <Setter Property="Data" Value="{StaticResource InfoIcon}"/>
            <Setter Property="Fill" Value="#9CA3AF"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
        </Style>
        <Style x:Key="TipTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="TipBody" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxWidth" Value="300"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: title + action buttons -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="MicMixer" FontSize="22" FontWeight="SemiBold" Foreground="#10233A"/>
                    <TextBlock x:Name="VersionText" FontSize="11" Foreground="#9CA3AF" Margin="8,0,0,4"
                               VerticalAlignment="Bottom"/>
                </StackPanel>
                <TextBlock Foreground="#6B7280" FontSize="11.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                           Text="Virtual mic switch — hold the hotkey for the modded mic"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ToggleBtn" Click="OnToggleClick" Height="32" Padding="14,0" FontWeight="SemiBold"
                        Background="#10233A" Foreground="White" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Path x:Name="ToggleBtnIcon" Data="{StaticResource PlayIcon}" Fill="White"
                              Style="{StaticResource SectionIcon}" Width="13" Height="13" Margin="0,0,7,0"/>
                        <TextBlock x:Name="ToggleBtnText" Text="Enable" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button Click="OnRefreshClick" Height="32" Width="32" Margin="8,0,0,0" Padding="0"
                        Background="#E8EEF5" Foreground="#10233A" BorderBrush="#D7DEE7" BorderThickness="1"
                        ToolTip="Refresh devices">
                    <Path Data="{StaticResource RefreshIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content: routing to the left, music to the right. In narrow mode the
             music card takes the full width on top and the routing column folds
             into a compact status bar below (rows 1–2), toggled by the user. -->
        <Grid x:Name="ContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RoutingColumn" Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition x:Name="MusicColumn" Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Left column: devices, hotkey, status -->
            <ui:RoutingPanel x:Name="RoutingScroll" Grid.Column="0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Focusable="False">
            <!-- Keep the routing cards content-sized; the ScrollViewer only kicks in
                 when their combined natural height exceeds the available space. -->
            <Grid VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Device configuration — 3 columns side by side, stacked vertically
                     when the card gets too narrow (handled in code-behind) -->
                <Border Grid.Row="0" Margin="0,0,0,10" Padding="14" CornerRadius="12" Background="White" BorderBrush="#D7DEE7" BorderThickness="1">
                    <Grid x:Name="DeviceGrid" SizeChanged="OnDeviceGridSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Normal mic -->
                        <StackPanel x:Name="DryDevicePanel" Grid.Column="0" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="{StaticResource MicIcon}" Fill="{x:Static ui:StatusTheme.LiveBrush}" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Normal mic" FontWeight="SemiBold" FontSize="12" Foreground="#10233A"/>
                                <Border Style="{StaticResource InfoTipHost}">
                                    <Path Style="{StaticResource InfoTipIcon}"/>
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Your physical microphone"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="The microphone you actually speak into — the same one you normally select in other apps. This is the default source while routing is active."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>
                            <ComboBox x:Name="DryInputCombo" DisplayMemberPath="FriendlyName" SelectionChanged="OnSettingsSelectionChanged" FontSize="11.5"/>
                        </StackPanel>

                        <!-- Modded mic -->
                        <StackPanel x:Name="ModdedDevicePanel" Grid.Column="1" Margin="8,0,8,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="{StaticResource ModdedMicIcon}" Fill="{x:Static ui:StatusTheme.ModdedBrush}" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Modded mic" FontWeight="SemiBold" FontSize="12" Foreground="#10233A"/>
                                <Border Style="{StaticResource InfoTipHost}">
                                    <Path Style="{StaticResource InfoTipIcon}"/>
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Voice-modified microphone (e.g. Voicemod)"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="The output from a voice changer — for Voicemod, it is usually called 'Voicemod Virtual Audio Device'. While you hold the hotkey, this source is heard instead of your normal mic."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Not using a voice changer? Select 'No modded mic' — only the normal mic and music will be sent to the cable, and no hotkey is needed."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>
                            <ComboBox x:Name="ModdedInputCombo" DisplayMemberPath="FriendlyName" SelectionChanged="OnSettingsSelectionChanged" FontSize="11.5"/>
                        </StackPanel>

                        <!-- Output -->
                        <StackPanel x:Name="OutputDevicePanel" Grid.Column="2" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="{StaticResource CableIcon}" Fill="#4338CA" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Virtual cable output" FontWeight="SemiBold" FontSize="12" Foreground="#10233A"/>
                                <Border Style="{StaticResource InfoTipHost}">
                                    <Path Style="{StaticResource InfoTipIcon}"/>
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="The finished mix is sent here"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="Select CABLE Input (VB-Audio Virtual Cable). Everything being routed — mic and music — is played here; then select CABLE Output as the microphone in the receiving app."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Don't have VB-CABLE installed? Follow the guide at the bottom of the window."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>
                            <ComboBox x:Name="OutputDeviceCombo" DisplayMemberPath="FriendlyName" SelectionChanged="OnSettingsSelectionChanged" FontSize="11.5"/>
                            <TextBlock x:Name="OutputCableWarningText" Margin="0,5,0,0" FontSize="11" TextWrapping="Wrap"
                                       Foreground="#B45309" Visibility="Collapsed"
                                       Text="⚠ This does not appear to be a virtual cable. A receiving app can hear the mix only if it is sent to a device such as CABLE Input (VB-CABLE)."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Secondary output: optional fanout of the finished mix, tapped before
                     the push-to-talk gate. Off by default — the cable path is untouched. -->
                <Border Grid.Row="2" Margin="0,0,0,10" Padding="14" CornerRadius="12" Background="White" BorderBrush="#D7DEE7" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource SpeakerIcon}" Fill="#0E7490" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Secondary output" FontWeight="SemiBold" FontSize="12" Foreground="#10233A" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource InfoTipHost}">
                                    <Path Style="{StaticResource InfoTipIcon}"/>
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Additional output for recording or streaming"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="Plays the exact same mix sent to the cable (mic + music) on an additional audio device. The cable output used by your voice chat or game is not affected."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Typical use case: recording or streaming the mix. Select a device here and add the same device as an audio output capture source in your streaming software."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="With 'Ignore push-to-talk', the mic and music are always heard here — even when PTT is released and the cable receives silence. Unlike Monitoring, which plays only the music, the secondary output plays the entire mix including your voice."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Don't need to record or listen to the entire mix separately? Leave this disabled — everything else will work as usual."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>
                            <CheckBox x:Name="SecondaryOutputEnabledCheck" Grid.Column="1" VerticalAlignment="Center" FontSize="11.5" Foreground="#10233A"
                                      Checked="OnSecondaryOutputConfigChanged" Unchecked="OnSecondaryOutputConfigChanged"
                                      ToolTipService.ShowDuration="60000"
                                      ToolTip="Also play the mix on the device below. Takes effect the next time routing starts.">
                                <TextBlock Text="Enable" VerticalAlignment="Center"/>
                            </CheckBox>
                        </Grid>

                        <StackPanel x:Name="SecondaryOutputConfigPanel" Margin="0,6,0,0"
                                    IsEnabled="{Binding IsChecked, ElementName=SecondaryOutputEnabledCheck}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <ComboBox x:Name="SecondaryOutputCombo" DisplayMemberPath="FriendlyName" FontSize="11.5"
                                      SelectionChanged="OnSecondaryOutputDeviceChanged"
                                      ToolTipService.ShowDuration="60000"
                                      ToolTip="The device that also plays the mix — for example, one captured by an audio output source in your streaming software. Do not select the same device as the virtual cable output."/>
                            <TextBlock x:Name="SecondaryOutputWarningText" Margin="0,5,0,0" FontSize="11" TextWrapping="Wrap"
                                       Foreground="#B91C1C" Visibility="Collapsed"
                                       Text="⚠ Same device as the virtual cable output — the mix would play twice. Select a different device."/>

                            <CheckBox x:Name="SecondaryIgnorePttCheck" Margin="0,8,0,0" FontSize="11.5" Foreground="#10233A" IsChecked="True"
                                      Checked="OnSecondaryOutputConfigChanged" Unchecked="OnSecondaryOutputConfigChanged"
                                      ToolTipService.ShowDuration="60000">
                                <TextBlock Text="Ignore push-to-talk — mic and music are heard here even when the cable is silent"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource TipTitle}" Text="Play even when push-to-talk is released"/>
                                            <TextBlock Style="{StaticResource TipBody}"
                                                       Text="On (default): the secondary output always receives mic and music, even when push-to-talk keeps the cable silent — for example, so a recording includes everything you say. Off: the mic on the secondary output follows push-to-talk and becomes silent with the cable."/>
                                            <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                       Text="Music always follows what you can hear: it remains on the secondary output while it is sent to the cable or previewed in monitor-only mode."/>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                            </CheckBox>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Volume" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="SecondaryVolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" Value="1"
                                        VerticalAlignment="Center" LargeChange="0" SmallChange="0.05"
                                        ValueChanged="OnSecondaryVolumeChanged"
                                        ToolTip="Volume for the secondary output only — does not affect the cable"/>
                                <TextBlock x:Name="SecondaryVolumePercentText" Grid.Column="2" Text="100 %" FontSize="11" Foreground="#10233A"
                                           FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="34" TextAlignment="Right"/>
                            </Grid>

                            <TextBlock x:Name="SecondaryOutputStatusText" Margin="0,6,0,0" FontSize="10.5" Foreground="#9CA3AF"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hotkey + delay row -->
                <Border x:Name="HotkeyDelayCard" Grid.Row="1" Margin="0,0,0,10" Padding="14" CornerRadius="12" Background="White" BorderBrush="#D7DEE7" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="HotkeyConfigPanel" Grid.Row="0" SizeChanged="OnHotkeyConfigSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Hotkey -->
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="{StaticResource HotkeyIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Global hotkey" FontWeight="SemiBold" FontSize="12" Foreground="#10233A"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="8,5" CornerRadius="6" Background="#F8FAFC" BorderBrush="#D7DEE7" BorderThickness="1" MinWidth="80">
                                    <TextBlock x:Name="HotkeyValueText" FontWeight="SemiBold" Foreground="#10233A" FontSize="12" HorizontalAlignment="Center"/>
                                </Border>
                                <Button x:Name="CaptureHotkeyButton" Margin="8,0,0,0" Height="28" Padding="10,0"
                                        Click="OnCaptureHotkeyClick" Content="Change" FontSize="11.5"
                                        Background="#E8EEF5" Foreground="#10233A" BorderBrush="#D7DEE7" BorderThickness="1"/>
                            </StackPanel>
                            <TextBlock x:Name="HotkeyCaptureHintText" Margin="0,5,0,0" FontSize="10.5" Foreground="#9CA3AF" TextWrapping="Wrap"
                                       Text="Click Change, then press any keyboard key or mouse button."/>
                        </StackPanel>

                        <!-- Delay -->
                        <StackPanel x:Name="DelayPanel" Grid.Column="1" VerticalAlignment="Center" MinWidth="140">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="{StaticResource ClockIcon}" Fill="#6B7280" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Release delay" FontWeight="SemiBold" FontSize="12" Foreground="#10233A"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ReleaseDelayTextBox" Width="64" MaxLength="5" Height="28"
                                         VerticalContentAlignment="Center" FontSize="12"
                                         LostFocus="OnReleaseDelayTextBoxLostFocus" KeyDown="OnReleaseDelayTextBoxKeyDown"/>
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12" Text="ms"/>
                            </StackPanel>
                            <TextBlock Margin="0,5,0,0" FontSize="10.5" Foreground="#9CA3AF" Text="0 = immediate release"/>
                        </StackPanel>
                        </Grid>

                        <!-- Push-to-talk: gate for the whole outgoing mix. Lives outside
                             HotkeyConfigPanel so it stays clickable when the hotkey config
                             is dimmed for "No modded mic". -->
                        <Border Grid.Row="1" Margin="0,10,0,0" Padding="0,10,0,0" BorderBrush="#E9EEF3" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <CheckBox x:Name="PushToTalkCheck" FontSize="11.5" Foreground="#10233A"
                                          Checked="OnPushToTalkChanged" Unchecked="OnPushToTalkChanged"
                                          ToolTipService.ShowDuration="60000">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Data="{StaticResource MicOffIcon}" Fill="{x:Static ui:StatusTheme.MutedBrush}" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,5,0"/>
                                        <TextBlock Grid.Column="1" Text="Push-to-talk — everything is silent until the hotkey is held" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Push-to-talk for the entire mix"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="When this is on, only silence is sent to the virtual cable — neither mic nor music is heard — until you hold the hotkey. This also works with 'No modded mic': your normal mic is heard only while the hotkey is held."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Want the music to remain audible while your voice is muted? Enable 'Music ignores push-to-talk' in the music card — push-to-talk will then affect only the mic."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="The release delay applies here too: audio remains active briefly after you let go. Monitoring through your own headphones is unaffected, so you continue to hear the music."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox x:Name="OverlayIndicatorCheck" Margin="0,8,0,0" FontSize="11.5" Foreground="#10233A"
                                          Checked="OnOverlayIndicatorChanged" Unchecked="OnOverlayIndicatorChanged"
                                          ToolTipService.ShowDuration="60000">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Data="{StaticResource MicIcon}" Fill="{x:Static ui:StatusTheme.LiveBrush}" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,5,0"/>
                                        <TextBlock Grid.Column="1" Text="Overlay indicator — status dot in the top right, including over games" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="On-screen status indicator"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="Shows a small translucent dot in the top-right corner while routing is active — using the same colors as the system tray icon: green = normal mic is live, blue = modded mic is live (hotkey held), red crossed-out mic = muted (push-to-talk)."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="When music is playing, a separate music circle appears to the left of the dot with animated equalizer bars: purple note = music is sent to the mic channel, amber headphones = monitor only (only you and any secondary output can hear it), gray crossed-out note = music is playing but blocked by push-to-talk."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="The indicators are click-through and remain visible over games in windowed or borderless mode. Games in exclusive fullscreen cannot display overlays."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox x:Name="OverlayVolumeMeterCheck" Margin="22,6,0,0" FontSize="11.5" Foreground="#10233A"
                                          Checked="OnOverlayVolumeMeterChanged" Unchecked="OnOverlayVolumeMeterChanged"
                                          ToolTipService.ShowDuration="60000">
                                    <!-- The meter applies to both the desktop overlay and the stream
                                         overlay, so either of them enables the checkbox. -->
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=OverlayIndicatorCheck}" Value="True">
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=ObsOverlayCheck}" Value="True">
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                    <TextBlock Text="Volume meter — level rings around the indicators show whether the audio level is good" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Output audio volume meter"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="Shows a level ring around each indicator while routing is active — the ring fills clockwise with the audio level, and a small white marker briefly holds the latest peak. The mic dot's ring measures everything sent to the mic channel — voice and music together, exactly what others hear. The music circle's ring measures only the music (after music volume), so you can set the level in monitor-only mode before others hear it."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="The color indicates the level: green = good, yellow = too low or too high, red = far too high or clipping (lower the volume). The meters reflect perceived loudness, not just peaks — heavily compressed music that sounds loud reads high even without clipping. When push-to-talk is muted, the mic ring is empty because nothing is being sent."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <!-- Meter calibration: shifts the whole dB window so ring fill and
                                     color bands react earlier/later. Active only while the meter itself
                                     is both available (overlay on) and enabled. -->
                                <Grid Margin="40,4,0,0" ToolTipService.ShowDuration="60000" ToolTipService.ShowOnDisabled="True">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsChecked, ElementName=OverlayIndicatorCheck}" Value="True"/>
                                                        <Condition Binding="{Binding IsChecked, ElementName=OverlayVolumeMeterCheck}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsChecked, ElementName=ObsOverlayCheck}" Value="True"/>
                                                        <Condition Binding="{Binding IsChecked, ElementName=OverlayVolumeMeterCheck}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                </MultiDataTrigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="MeterSensitivityLabel" Text="Sensitivity" FontSize="10.5" Foreground="#6B7280"
                                               VerticalAlignment="Center" Margin="0,0,8,0" Cursor="Hand"
                                               MouseLeftButtonDown="OnMeterSensitivityLabelMouseDown"/>
                                    <Slider x:Name="MeterSensitivitySlider" Grid.Column="1" Width="130" VerticalAlignment="Center"
                                            Minimum="-12" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                            SmallChange="1" LargeChange="0"
                                            ValueChanged="OnMeterSensitivityChanged"/>
                                    <TextBlock x:Name="MeterSensitivityValueText" Grid.Column="2" Text="±0 dB" FontSize="10.5"
                                               Foreground="#9CA3AF" VerticalAlignment="Center" Margin="8,0,0,0"
                                               MinWidth="42" TextAlignment="Right"/>
                                    <Grid.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Calibrate the volume meter"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="If others say you sound louder than the meter indicates, increase the sensitivity so it turns yellow or red sooner. If they say you sound quieter, decrease it. The default (±0 dB) suits most users."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="Changes appear in the meter as you drag. Double-click the word Sensitivity to reset it. The red clipping flash is unaffected — clipping is always clipping."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                </Grid>
                                <CheckBox x:Name="ObsOverlayCheck" Margin="0,8,0,0" FontSize="11.5" Foreground="#10233A"
                                          Checked="OnObsOverlayChanged" Unchecked="OnObsOverlayChanged"
                                          ToolTipService.ShowDuration="60000">
                                    <TextBlock Text="Stream overlay — show the same overlay via a browser source"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TipTitle}" Text="Stream overlay for viewers"/>
                                                <TextBlock Style="{StaticResource TipBody}"
                                                           Text="If your streaming software captures only the game, the on-screen overlay may not be visible on stream. This starts a small local web page that displays the same overlay — circles, level rings, and equalizer — so it can be added as a separate layer over the game."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="In your streaming software (for example, OBS Studio or Streamlabs Desktop): add a browser source, paste the address below, set a size such as 232 × 116, and place it where you want. The page is transparent and shows nothing while routing is stopped — just like the on-screen overlay. Append ?opacity=1 to the address for fully opaque circles."/>
                                                <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                           Text="The server is accessible only from this computer (127.0.0.1) and sends only status and audio levels — no audio or video. It works independently of the on-screen overlay above, so you can use either, both, or neither."/>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <!-- Server address and port. Visible only while the stream overlay is on;
                                     the port rarely needs changing (only on a conflict). -->
                                <StackPanel Margin="22,4,0,0"
                                            Visibility="{Binding IsChecked, ElementName=ObsOverlayCheck, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Port" FontSize="10.5" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="ObsOverlayPortBox" Width="56" MaxLength="5" Height="24" FontSize="11"
                                                 VerticalContentAlignment="Center"
                                                 LostFocus="OnObsOverlayPortBoxLostFocus" KeyDown="OnObsOverlayPortBoxKeyDown"
                                                 ToolTip="Local port for the overlay page. Change it only if another application is using the port."/>
                                        <Button Content="Copy address" Margin="10,0,0,0" Padding="8,2" FontSize="10.5"
                                                VerticalAlignment="Center" Click="OnObsOverlayCopyClick"
                                                ToolTip="Copies the overlay address so you can paste it into a browser source in your streaming software."/>
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="#6B7280" TextWrapping="Wrap">
                                        <Hyperlink Click="OnObsOverlayLinkClick" ToolTip="Open the overlay page in your browser to test it.">
                                            <Run x:Name="ObsOverlayLinkText"/>
                                        </Hyperlink><Run x:Name="ObsOverlayClientsText"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,10,0,0" Padding="0,10,0,0"
                                BorderBrush="#E9EEF3" BorderThickness="0,1,0,0">
                            <CheckBox x:Name="StartWithWindowsCheck" FontSize="11.5" Foreground="#10233A"
                                      Checked="OnStartWithWindowsChanged" Unchecked="OnStartWithWindowsChanged"
                                      ToolTipService.ShowDuration="60000">
                                <TextBlock Text="Start with Windows — opens minimized in the system tray"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource TipTitle}" Text="Start MicMixer automatically"/>
                                            <TextBlock Style="{StaticResource TipBody}"
                                                       Text="Adds MicMixer to Windows startup. When you sign in, the app starts hidden in the system tray without opening the main window."/>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                            </CheckBox>
                        </Border>
                    </Grid>
                </Border>

                <!-- Live status panel -->
                <Border Grid.Row="3" Padding="14" CornerRadius="12" Background="White" BorderBrush="#D7DEE7" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Status header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Path x:Name="RoutingStateIcon" Data="{StaticResource CircleOffIcon}" Fill="#9CA3AF"
                                  Style="{StaticResource SectionIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="RoutingStateText" Text="Routing stopped" FontSize="14" FontWeight="SemiBold" Foreground="#10233A" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock x:Name="ActiveSourceText" Text="Active source: None" Foreground="{x:Static ui:StatusTheme.StoppedInkBrush}" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="HotkeyStateText" Margin="0,2,0,0" Text="No hotkey selected" Foreground="#6B7280" FontSize="11.5"/>
                        </StackPanel>

                        <!-- Level meters -->
                        <Border Grid.Row="2" VerticalAlignment="Top" Padding="12,7" CornerRadius="8"
                                Background="#F8FAFC" BorderBrush="#E9EEF3" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="DryMeterPanel" Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Path Data="{StaticResource MicIcon}" Fill="{x:Static ui:StatusTheme.LiveBrush}" Style="{StaticResource SectionIcon}" Width="11" Height="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Normal" FontSize="11" Foreground="#6B7280"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="DryLevelMeter" Height="8" Minimum="0" Maximum="1" Foreground="{x:Static ui:StatusTheme.LiveBrush}" Background="#E5E7EB"/>
                                </StackPanel>
                                <StackPanel x:Name="ModdedMeterPanel" Grid.Column="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Path Data="{StaticResource ModdedMicIcon}" Fill="{x:Static ui:StatusTheme.ModdedBrush}" Style="{StaticResource SectionIcon}" Width="11" Height="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Modded" FontSize="11" Foreground="#6B7280"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="ModdedLevelMeter" Height="8" Minimum="0" Maximum="1" Foreground="{x:Static ui:StatusTheme.ModdedBrush}" Background="#E5E7EB"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Status text (pinned to the bottom of the card) -->
                        <TextBlock x:Name="StatusText" Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Bottom"
                                   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11"/>
                    </Grid>
                </Border>
            </Grid>
            </ui:RoutingPanel>

            <!-- Compact status bar — narrow mode only. Mirrors the routing state and
                 toggles the folded-away routing panel. -->
            <ToggleButton x:Name="CompactStatusToggle" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          Margin="0,10,0,0" Visibility="Collapsed" Cursor="Hand"
                          Checked="OnCompactStatusToggled" Unchecked="OnCompactStatusToggled"
                          ToolTip="Show or hide mic routing and settings" ToolTipService.ShowDuration="30000">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BarBg" Background="White" CornerRadius="12" BorderBrush="#D7DEE7" BorderThickness="1" Padding="14,9">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BarBg" Property="Background" Value="#FBFCFE"/>
                                <Setter TargetName="BarBg" Property="BorderBrush" Value="#C9D2DD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="CompactStatusDot" Width="9" Height="9" Fill="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CompactStatusText" Grid.Column="1" Text="Routing stopped" FontSize="12" FontWeight="SemiBold"
                               Foreground="#10233A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="CompactStatusHint" Grid.Column="2" Text="Show settings" FontSize="11" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="8,0,6,0"/>
                    <Path x:Name="CompactStatusChevron" Grid.Column="3" Data="{StaticResource ChevronUpIcon}" Fill="#6B7280"
                          Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="CompactChevronRotate" Angle="180"/>
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </ToggleButton>

            <!-- Right column: music player -->
            <ui:MusicPanel x:Name="MusicCard" Grid.Column="2" Padding="14" Background="White"
                           BorderBrush="#D7DEE7" BorderThickness="1" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header + monitor selection. The monitor device combo drops to its
                         own row when the card is narrow (handled in code-behind). -->
                    <Grid x:Name="MusicHeaderGrid" Grid.Row="0" Margin="0,0,0,8" SizeChanged="OnMusicHeaderSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource MusicIcon}" Fill="#7C3AED" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Music into the mic channel" FontWeight="SemiBold" FontSize="12" Foreground="#10233A" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource InfoTipHost}">
                                <Path Style="{StaticResource InfoTipIcon}"/>
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource TipTitle}" Text="How music works"/>
                                            <TextBlock Style="{StaticResource TipBody}"
                                                       Text="Music is mixed into the mic channel with your voice so others can hear it whenever a track is playing and routing is active."/>
                                            <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                       Text="In MP3 / YouTube mode, download tracks from a YouTube link or add your own MP3 files to the music folder (folder icon on the right; the gear lets you add multiple music folders). In External app mode, audio from a music app is captured and mixed in directly."/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                            </Border>
                        </StackPanel>
                        <CheckBox x:Name="MonitorEnabledCheck" Grid.Column="1" VerticalAlignment="Center" FontSize="11.5" Foreground="#10233A"
                                  Checked="OnMonitorConfigChanged" Unchecked="OnMonitorConfigChanged"
                                  ToolTipService.ShowDuration="60000" ToolTipService.ShowOnDisabled="True"
                                  ToolTip="Also play the music through your own headphones or speakers so you can hear it. This does not affect what others hear. Monitoring is not needed in app mode because you hear the app directly.">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeadphonesIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Monitoring" VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox>
                        <ComboBox x:Name="MonitorDeviceCombo" Grid.Column="2" Width="170" Margin="10,0,0,0" FontSize="11"
                                  DisplayMemberPath="FriendlyName" SelectionChanged="OnMonitorDeviceSelectionChanged"
                                  ToolTipService.ShowDuration="60000"
                                  ToolTip="The output where you want to hear the music — select your headphones or speakers, not the virtual cable. Others hear the music through the mic channel regardless."/>
                    </Grid>

                    <!-- Source mode switch: local library vs external app capture -->
                    <Border Grid.Row="1" Margin="0,0,0,8" Background="#E8EEF5" CornerRadius="8" Padding="2">
                        <UniformGrid Rows="1" Columns="2">
                            <RadioButton x:Name="LibraryModeRadio" Style="{StaticResource ModeSegment}" GroupName="MusicMode"
                                         IsChecked="True" Checked="OnMusicModeChanged" Content="MP3 / YouTube"
                                         ToolTip="Play downloaded MP3 files from the music folder."/>
                            <RadioButton x:Name="ExternalModeRadio" Style="{StaticResource ModeSegment}" GroupName="MusicMode"
                                         Checked="OnMusicModeChanged" Content="External app"
                                         ToolTip="Capture audio from an app playing music and mix it into the mic channel. Control playback in the app."/>
                        </UniformGrid>
                    </Border>

                    <!-- Download panel: URL, target folder and progress share one state/render boundary. -->
                    <ui:DownloadPanel Grid.Row="2" Grid.RowSpan="2">
                      <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    <!-- YouTube URL row -->
                    <Grid x:Name="YoutubeRow" Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="YoutubeUrlBox" Height="28" VerticalContentAlignment="Center" FontSize="11.5"
                                     KeyDown="OnYoutubeUrlKeyDown" TextChanged="OnYoutubeUrlChanged"/>
                            <TextBlock x:Name="YoutubeUrlHintText" Text="Paste a YouTube link here..." FontSize="11.5"
                                       Foreground="#9CA3AF" Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                        <!-- Download target folder — only shown when more than one music folder is active -->
                        <ComboBox x:Name="DownloadFolderCombo" Grid.Column="1" Height="28" MaxWidth="150" Margin="8,0,0,0"
                                  Visibility="Collapsed" FontSize="11" VerticalContentAlignment="Center"
                                  SelectionChanged="OnDownloadFolderChanged"
                                  ToolTipService.ShowDuration="60000"
                                  ToolTip="Folder for new downloads">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding Path}" ToolTipService.ShowDuration="60000">
                                        <Border Background="{Binding Tint}" CornerRadius="6" Padding="5,0" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Letter}" FontSize="9.5" FontWeight="SemiBold" Foreground="{Binding Accent}"/>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button x:Name="DownloadBtn" Grid.Column="2" Height="28" Margin="8,0,0,0" Padding="10,0"
                                Click="OnDownloadClick" FontSize="11.5" FontWeight="SemiBold"
                                Background="#E8EEF5" Foreground="#10233A" BorderBrush="#D7DEE7" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource DownloadIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock Text="Download MP3" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Download progress -->
                    <Grid Grid.Row="1" x:Name="DownloadStatusRow" Visibility="Collapsed" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="DownloadProgressBar" Height="6" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                     Foreground="#7C3AED" Background="#E5E7EB"/>
                        <TextBlock x:Name="DownloadStatusText" Grid.Column="1" Margin="8,0,0,0" FontSize="10.5" Foreground="#6B7280" VerticalAlignment="Center"/>
                    </Grid>
                      </Grid>
                    </ui:DownloadPanel>

                    <!-- Search / filter -->
                    <Grid x:Name="SearchRow" Grid.Row="4" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="{StaticResource SearchIcon}" Fill="#9CA3AF" Style="{StaticResource SectionIcon}" Width="13" Height="13" Margin="0,0,6,0"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="PlaylistFilterBox" Height="26" VerticalContentAlignment="Center" FontSize="11.5"
                                     TextChanged="OnPlaylistFilterChanged"/>
                            <TextBlock x:Name="PlaylistFilterHintText" Text="Search the playlist..." FontSize="11.5"
                                       Foreground="#9CA3AF" Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                        <!-- Folder filter chips — one per music folder, shown when several folders are active.
                             Toggling a chip narrows the list to that folder; no active chip shows everything. -->
                        <ItemsControl x:Name="FolderChipsPanel" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton IsChecked="{Binding IsActive, Mode=TwoWay}" Click="OnFolderChipClick" Cursor="Hand"
                                                  Margin="4,0,0,0" Opacity="{Binding ChipOpacity}"
                                                  ToolTip="{Binding ToolTipText}" ToolTipService.ShowDuration="60000">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{Binding ChipBackground}" CornerRadius="9" MinWidth="18" Height="18" Padding="5,0">
                                                    <TextBlock Text="{Binding Letter}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding ChipForeground}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Playlist (fills remaining height). The button column moves to a
                         horizontal row under the list when height is scarce (code-behind). -->
                    <Grid x:Name="PlaylistRow" Grid.Row="5" Margin="0,0,0,8" SizeChanged="OnPlaylistRowSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="PlaylistListBox" FontSize="11.5"
                                 MouseDoubleClick="OnPlaylistDoubleClick" BorderBrush="#D7DEE7"
                                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Data="{StaticResource PlayIcon}" Fill="#7C3AED" Width="9" Height="9" Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,5,0" Visibility="{Binding PlayingVisibility}"/>
                                        <!-- Folder badge: first letter of the source folder, shown when several folders are active -->
                                        <Border Grid.Column="1" Background="{Binding FolderBadgeBackground}" CornerRadius="6" Padding="5,1" Margin="0,0,6,0"
                                                VerticalAlignment="Center" Visibility="{Binding FolderBadgeVisibility}"
                                                ToolTip="{Binding FolderPath}" ToolTipService.ShowDuration="60000">
                                            <TextBlock Text="{Binding FolderLetter}" FontSize="9.5" FontWeight="SemiBold" Foreground="{Binding FolderBadgeForeground}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="3" Background="#EDE9FE" CornerRadius="8" Padding="6,1" Margin="8,0,0,0"
                                                VerticalAlignment="Center" Visibility="{Binding QueueVisibility}"
                                                ToolTip="Queue position">
                                            <TextBlock Text="{Binding QueueText}" FontSize="10" FontWeight="SemiBold" Foreground="#7C3AED"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel x:Name="PlaylistButtonsPanel" Grid.Column="1" Margin="8,0,0,0">
                            <Button Height="28" Width="28" Padding="0" Click="OnQueueClick" ToolTip="Add the selected track to the queue"
                                    Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                <Path Data="{StaticResource QueueIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                            </Button>
                            <Button Height="28" Width="28" Padding="0" Margin="0,6,0,0" Click="OnPlaylistRefreshClick" ToolTip="Refresh the playlist"
                                    Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                <Path Data="{StaticResource RefreshIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="12" Height="12"/>
                            </Button>
                            <Button x:Name="OpenMusicFolderBtn" Height="28" Width="28" Padding="0" Margin="0,6,0,0" Click="OnOpenMusicFolderClick" ToolTip="Open the music folder"
                                    Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                <Path Data="{StaticResource FolderIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                            </Button>
                            <Button x:Name="MusicFolderOptionsBtn" Height="28" Width="28" Padding="0" Margin="0,6,0,0"
                                    Click="OnMusicFolderOptionsClick" ToolTipService.ShowDuration="30000"
                                    ToolTip="Music folders — add or remove folders containing tracks"
                                    Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                <Path Data="{StaticResource CogIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- External app capture (replaces the library rows in external mode) -->
                    <Grid x:Name="ExternalPanel" Grid.Row="2" Grid.RowSpan="4" Margin="0,0,0,8" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- App picker + capture toggle -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ExternalAppCombo" Height="28" VerticalContentAlignment="Center" FontSize="11.5"
                                      DisplayMemberPath="FriendlyName" SelectionChanged="OnExternalAppSelectionChanged"
                                      ToolTipService.ShowDuration="60000"
                                      ToolTip="The list shows apps that have created an audio session in Windows. A newly started app therefore appears only after it has played audio."/>
                            <Button Grid.Column="1" Height="28" Width="28" Margin="6,0,0,0" Padding="0"
                                    Click="OnRefreshAudioAppsClick" ToolTip="Refresh after the app has played audio"
                                    Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                <Path Data="{StaticResource RefreshIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="12" Height="12"/>
                            </Button>
                            <Button x:Name="CaptureToggleBtn" Grid.Column="2" Height="28" Margin="8,0,0,0" Padding="10,0"
                                    Click="OnCaptureToggleClick" FontSize="11.5" FontWeight="SemiBold"
                                    Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" BorderThickness="1"
                                    ToolTipService.ShowDuration="60000"
                                    ToolTip="Starts or stops only audio capture from the app. Routing (the button in the top right) is not affected.">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="CaptureToggleIcon" Data="{StaticResource PlayIcon}" Fill="White"
                                          Style="{StaticResource SectionIcon}" Width="11" Height="11" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="CaptureToggleText" Text="Capture audio" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="1" Margin="2,0,2,8" FontSize="10.5" Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Text="The list shows apps with an audio session. If an app is missing, play something in it for a few seconds, then click Refresh."/>

                        <!-- Capture status card -->
                        <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E9EEF3" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Path x:Name="CaptureStateIcon" Data="{StaticResource CircleOffIcon}" Fill="#9CA3AF"
                                      Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CaptureStateText" Text="No audio capture" FontWeight="SemiBold" FontSize="12.5"
                                           Foreground="#10233A" HorizontalAlignment="Center" TextAlignment="Center"
                                           TextWrapping="Wrap" MaxWidth="340"/>
                                <ProgressBar x:Name="CaptureLevelMeter" Width="220" Height="8" Minimum="0" Maximum="1"
                                             Margin="0,10,0,0" Foreground="#7C3AED" Background="#E5E7EB"/>
                                <TextBlock x:Name="CaptureHintText" Margin="0,10,0,0" FontSize="10.5" Foreground="#9CA3AF"
                                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="340"
                                           Text="Select the app playing music and click Capture audio. Control playback in the app as usual — its audio is mixed into the mic channel."/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Contextual warning: playback/capture can be audible locally even though
                         nothing is currently being sent to the mic channel. -->
                    <Border x:Name="MusicRoutingWarning" Grid.Row="6" Margin="0,0,0,8" Padding="10,7"
                            Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1"
                            CornerRadius="7" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="!" Width="18" Height="18" Margin="0,0,8,0"
                                       VerticalAlignment="Top" TextAlignment="Center"
                                       FontSize="11" FontWeight="Bold" Foreground="#9A3412"
                                       Background="#FFEDD5"/>
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="#9A3412" TextWrapping="Wrap"
                                       Text="Routing is off. Music is heard only locally and is not sent to the mic channel — enable routing to let others hear it."/>
                        </Grid>
                    </Border>

                    <!-- Transport -->
                    <Grid Grid.Row="7" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Height="30" Width="30" Padding="0" Click="OnPrevTrackClick" ToolTip="Previous / restart"
                                Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                            <Path Data="{StaticResource SkipPrevIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                        </Button>
                        <Button Grid.Column="1" Height="30" Width="38" Padding="0" Margin="6,0,0,0" Click="OnPlayPauseClick" ToolTip="Play / pause"
                                Background="#10233A" BorderThickness="0">
                            <Path x:Name="PlayPauseIcon" Data="{StaticResource PlayIcon}" Fill="White" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                        </Button>
                        <Button Grid.Column="2" Height="30" Width="30" Padding="0" Margin="6,0,0,0" Click="OnStopPlaybackClick"
                                ToolTip="Stop and deselect the active track"
                                Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                            <Path Data="{StaticResource StopIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="12" Height="12"/>
                        </Button>
                        <Button Grid.Column="3" Height="30" Width="30" Padding="0" Margin="6,0,0,0" Click="OnNextTrackClick" ToolTip="Next track"
                                Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                            <Path Data="{StaticResource SkipNextIcon}" Fill="#10233A" Style="{StaticResource SectionIcon}" Width="13" Height="13"/>
                        </Button>
                        <!-- Delayed start: arm a countdown, then play — time to alt-tab back to the game.
                             Right-click picks the delay length; clicking again mid-countdown cancels. -->
                        <Button x:Name="DelayedPlayBtn" Grid.Column="4" Height="30" MinWidth="48" Padding="8,0" Margin="12,0,0,0"
                                Click="OnDelayedPlayClick" FontSize="11.5" FontWeight="SemiBold"
                                Background="#E8EEF5" Foreground="#10233A" BorderBrush="#D7DEE7" BorderThickness="1"
                                ToolTipService.ShowDuration="60000">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="DelayedPlayIcon" Data="{StaticResource TimedPlayIcon}" Fill="#10233A"
                                      Style="{StaticResource SectionIcon}" Width="13" Height="13" Margin="0,0,5,0"/>
                                <TextBlock x:Name="DelayedPlayText" Text="3 s" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TipTitle}" Text="Delayed playback"/>
                                        <TextBlock Style="{StaticResource TipBody}"
                                                   Text="A play button with a countdown: click it to start the music after a few seconds, giving you time to switch back to the game before the track begins. Click again during the countdown to cancel."/>
                                        <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                   Text="Right-click the button to select the delay duration."/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="DelayedStartMenu" Opened="OnDelayedStartMenuOpened">
                                    <MenuItem Header="Delay before playback" IsEnabled="False" FontWeight="SemiBold"/>
                                    <Separator/>
                                    <MenuItem Header="1 second" Tag="1" Click="OnDelayedStartOptionClick"/>
                                    <MenuItem Header="2 seconds" Tag="2" Click="OnDelayedStartOptionClick"/>
                                    <MenuItem Header="3 seconds" Tag="3" Click="OnDelayedStartOptionClick"/>
                                    <MenuItem Header="5 seconds" Tag="5" Click="OnDelayedStartOptionClick"/>
                                    <MenuItem Header="10 seconds" Tag="10" Click="OnDelayedStartOptionClick"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <!-- Single-track mode: stop when the current track ends instead of auto-advancing.
                             Three states driven by Tag from code-behind: Off, Once (tinted — resets
                             itself after the track), Always (solid purple — double-click, stays on). -->
                        <Button x:Name="SingleTrackBtn" Grid.Column="5" Height="30" Width="30" Margin="6,0,0,0" Cursor="Hand"
                                Tag="Off" PreviewMouseLeftButtonDown="OnSingleTrackMouseDown"
                                ToolTipService.ShowDuration="60000" ToolTipService.ShowOnDisabled="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SingleTrackBg" Background="#E8EEF5" BorderBrush="#D7DEE7" BorderThickness="1">
                                        <Path x:Name="SingleTrackIconPath" Data="{StaticResource SingleTrackIcon}" Fill="#10233A"
                                              Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SingleTrackBg" Property="Background" Value="#DDE6F0"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Once">
                                            <Setter TargetName="SingleTrackBg" Property="Background" Value="#EDE9FE"/>
                                            <Setter TargetName="SingleTrackBg" Property="BorderBrush" Value="#7C3AED"/>
                                            <Setter TargetName="SingleTrackIconPath" Property="Fill" Value="#7C3AED"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Always">
                                            <Setter TargetName="SingleTrackBg" Property="Background" Value="#7C3AED"/>
                                            <Setter TargetName="SingleTrackBg" Property="BorderBrush" Value="#7C3AED"/>
                                            <Setter TargetName="SingleTrackIconPath" Property="Fill" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TipTitle}" Text="Play one track only"/>
                                        <TextBlock Style="{StaticResource TipBody}"
                                                   Text="Single click: music stops when the current track ends, then the mode turns itself off. Ideal when you want to play just one track."/>
                                        <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                   Text="Double-click: the mode stays on (the button becomes solid purple), and music stops after every track until you turn it off."/>
                                        <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                   Text="The queue remains and the Next button works as usual — only automatic advancement is stopped."/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <Slider x:Name="SeekSlider" Grid.Column="6" Margin="12,0,8,0" VerticalAlignment="Center"
                                Minimum="0" Maximum="1" IsMoveToPointEnabled="True"
                                Thumb.DragStarted="OnSeekDragStarted" Thumb.DragCompleted="OnSeekDragCompleted" ValueChanged="OnSeekValueChanged"/>
                        <TextBlock x:Name="ExternalTransportHint" Grid.Column="6" Margin="12,0,8,0" VerticalAlignment="Center"
                                   FontSize="10.5" Foreground="#9CA3AF" TextWrapping="Wrap" Visibility="Collapsed"
                                   Text="The buttons send media keys to the app that is playing."/>
                        <TextBlock x:Name="TrackTimeText" Grid.Column="7" Text="0:00 / 0:00" FontSize="11" Foreground="#6B7280"
                                   VerticalAlignment="Center" MinWidth="76" TextAlignment="Right"/>
                    </Grid>

                    <!-- Volumes (drag only — no jump on track click). Folds into two
                         stacked rows when the card is narrow (handled in code-behind). -->
                    <Grid x:Name="VolumesGrid" Grid.Row="8" SizeChanged="OnVolumesGridSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition x:Name="MonitorSliderColumn" Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="MusicVolumeLabel" Text="Music volume" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="MusicVolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" VerticalAlignment="Center"
                                LargeChange="0" SmallChange="0.05"
                                ValueChanged="OnMusicVolumeChanged" ToolTip="How loud others hear the music (in the mic channel)"/>
                        <TextBlock x:Name="MusicVolumePercentText" Grid.Column="2" Text="50 %" FontSize="11" Foreground="#10233A"
                                   FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="34" TextAlignment="Right"/>
                        <ToggleButton x:Name="VolumeLinkToggle" Grid.Column="3" Width="24" Height="24" Margin="6,0" Cursor="Hand"
                                      Checked="OnVolumeLinkChanged" Unchecked="OnVolumeLinkChanged"
                                      ToolTipService.ShowDuration="60000" ToolTipService.ShowOnDisabled="True"
                                      ToolTip="Link volumes — drag one slider and the other follows while preserving the difference between them. If a slider reaches 0 or maximum, it stays there, but the difference returns when you drag the other way.">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="LinkBg" Background="Transparent" CornerRadius="6">
                                        <Path x:Name="LinkIconPath" Data="{StaticResource LinkIcon}" Fill="#9CA3AF" Width="14" Height="14"
                                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="LinkBg" Property="Background" Value="#E8EEF5"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="LinkBg" Property="Background" Value="#EDE9FE"/>
                                            <Setter TargetName="LinkIconPath" Property="Fill" Value="#7C3AED"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <TextBlock x:Name="MonitorVolumeLabel" Grid.Column="4" Text="Monitoring" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="MonitorVolumeSlider" Grid.Column="5" Minimum="0" Maximum="1" VerticalAlignment="Center"
                                LargeChange="0" SmallChange="0.05"
                                ValueChanged="OnMonitorVolumeChanged" ToolTip="How loud the music is in your own headphones"/>
                        <TextBlock x:Name="MonitorVolumePercentText" Grid.Column="6" Text="50 %" FontSize="11" Foreground="#10233A"
                                   FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="34" TextAlignment="Right"/>
                    </Grid>

                    <!-- Music routing: how the music relates to push-to-talk and the cable.
                         Both are honest-by-default toggles — the hint text and the overlay's
                         music circle always tell where the music actually goes. -->
                    <StackPanel Grid.Row="9" Margin="0,8,0,0">
                        <CheckBox x:Name="MusicIgnorePttCheck" FontSize="11.5" Foreground="#10233A"
                                  Checked="OnMusicRoutingModeChanged" Unchecked="OnMusicRoutingModeChanged"
                                  IsEnabled="{Binding IsChecked, ElementName=PushToTalkCheck}"
                                  ToolTipService.ShowDuration="60000" ToolTipService.ShowOnDisabled="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource MusicIcon}" Fill="#7C3AED" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="Music ignores push-to-talk — music is transmitted while playing" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                            <CheckBox.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TipTitle}" Text="Music bypasses push-to-talk"/>
                                        <TextBlock Style="{StaticResource TipBody}"
                                                   Text="When this is on, music continues into the mic channel even while push-to-talk mutes the mic — ideal when the game should always hear the music but your voice is transmitted only while you hold the hotkey."/>
                                        <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                   Text="The mic always follows push-to-talk as usual. This option is active only when push-to-talk is on — without push-to-talk, music is transmitted whenever it plays."/>
                                    </StackPanel>
                                </ToolTip>
                            </CheckBox.ToolTip>
                        </CheckBox>
                        <CheckBox x:Name="MusicMonitorOnlyCheck" Margin="0,6,0,0" FontSize="11.5" Foreground="#10233A"
                                  Checked="OnMusicRoutingModeChanged" Unchecked="OnMusicRoutingModeChanged"
                                  ToolTipService.ShowDuration="60000">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource HeadphonesIcon}" Fill="#D97706" Style="{StaticResource SectionIcon}" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="Monitor only — preview without transmitting to the mic channel" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                            <CheckBox.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TipTitle}" Text="Preview the music"/>
                                        <TextBlock Style="{StaticResource TipBody}"
                                                   Text="When this is on, music is never sent to the mic channel — only you hear it through monitoring, so you can preview a track or set the volume before others hear it. The mic is not affected."/>
                                        <TextBlock Style="{StaticResource TipBody}" Margin="0,6,0,0"
                                                   Text="If the secondary output is active, it still receives the music — so your stream hears the same thing you do. The overlay's music circle shows amber headphones while this mode is on."/>
                                    </StackPanel>
                                </ToolTip>
                            </CheckBox.ToolTip>
                        </CheckBox>
                        <TextBlock x:Name="MusicRouteHintText" Margin="0,5,0,0" FontSize="10.5" Foreground="#9A3412"
                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Now playing + hints -->
                    <Grid Grid.Row="10" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- MinHeight reserves two text lines so status changes don't reflow the
                             card and shift the transport buttons mid-interaction. -->
                        <TextBlock x:Name="MusicStatusText" FontSize="10.5" Foreground="#9CA3AF" TextWrapping="Wrap"
                                   MinHeight="28"
                                   Text="Double-click a track to play it. Music is mixed with the mic while routing is active."/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="QueueChipBtn" Visibility="Collapsed" Cursor="Hand" Margin="8,0,0,0"
                                          Checked="OnQueueChipChecked" ToolTipService.ShowDuration="30000"
                                          ToolTip="Show the queue — drag tracks to reorder them">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ChipBg" Background="#EDE9FE" CornerRadius="8" Padding="7,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{TemplateBinding Content}" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                <Path Data="{StaticResource ChevronUpIcon}" Fill="#7C3AED" Width="9" Height="9"
                                                      Stretch="Uniform" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ChipBg" Property="Background" Value="#DDD6FE"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ChipBg" Property="Background" Value="#DDD6FE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Button x:Name="ClearQueueBtn" Height="18" Width="18" Padding="0" Margin="4,0,0,0" Visibility="Collapsed"
                                    Click="OnClearQueueClick" ToolTip="Clear the queue" Background="Transparent" BorderThickness="0">
                                <Path Data="{StaticResource CloseIcon}" Fill="#7C3AED" Style="{StaticResource SectionIcon}" Width="10" Height="10"/>
                            </Button>
                            <Popup x:Name="QueuePopup" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                                   PlacementTarget="{Binding ElementName=QueueChipBtn}" Placement="Top"
                                   IsOpen="{Binding IsChecked, ElementName=QueueChipBtn, Mode=TwoWay}"
                                   Closed="OnQueuePopupClosed">
                                <Border Background="White" BorderBrush="#C9D2DD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18"/>
                                    </Border.Effect>
                                    <Grid Width="300">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Upcoming tracks" FontWeight="SemiBold" FontSize="11.5" Foreground="#10233A" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Height="20" Padding="6,0" Click="OnClearQueueClick" Content="Clear"
                                                    FontSize="10.5" Background="#F3F4F6" Foreground="#6B7280" BorderBrush="#E5E7EB" BorderThickness="1"/>
                                        </Grid>
                                        <ListBox x:Name="QueueListBox" Grid.Row="1" MaxHeight="250" BorderThickness="0" Background="Transparent"
                                                 FontSize="11.5" AllowDrop="True"
                                                 VirtualizingPanel.IsVirtualizing="False"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 PreviewMouseLeftButtonDown="OnQueueListMouseDown"
                                                 PreviewMouseMove="OnQueueListMouseMove"
                                                 DragOver="OnQueueListDragOver" Drop="OnQueueListDrop" DragLeave="OnQueueListDragLeave"
                                                 MouseDoubleClick="OnQueueListDoubleClick">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="2,0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Border Height="2" Background="#7C3AED" CornerRadius="1" Visibility="{Binding InsertAboveVisibility}"/>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Path Data="{StaticResource DragHandleIcon}" Fill="#C4B5FD" Width="10" Height="12"
                                                                  Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0" Cursor="SizeAll"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding NumberText}" Foreground="#7C3AED" FontWeight="SemiBold"
                                                                       MinWidth="18" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="3" Width="18" Height="18" Padding="0" Margin="6,0,0,0"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                    Click="OnQueueRemoveClick" Tag="{Binding}" ToolTip="Remove from the queue">
                                                                <Path Data="{StaticResource CloseIcon}" Fill="#9CA3AF" Width="9" Height="9" Stretch="Uniform"/>
                                                            </Button>
                                                        </Grid>
                                                        <Border Height="2" Background="#7C3AED" CornerRadius="1" Visibility="{Binding InsertBelowVisibility}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <TextBlock Grid.Row="2" Margin="0,6,0,0" FontSize="10" Foreground="#9CA3AF" TextWrapping="Wrap"
                                                   Text="Drag to reorder · Double-click to play immediately"/>
                                    </Grid>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </Grid>
                </Grid>
            </ui:MusicPanel>
        </Grid>

        <!-- Collapsed help row -->
        <Expander Grid.Row="2" Margin="0,10,0,0" IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource InfoIcon}" Fill="#3B82F6" Style="{StaticResource SectionIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                    <TextBlock Text="VB-CABLE setup guide" FontWeight="SemiBold" FontSize="12" Foreground="#10233A" VerticalAlignment="Center"/>
                </StackPanel>
            </Expander.Header>
            <Border Padding="14,10" CornerRadius="0,0,10,10" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="0,1,0,0">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#1F2937" FontSize="11.5">
                        <Run Text="1. Install VB-CABLE from "/>
                        <Hyperlink NavigateUri="https://vb-audio.com/Cable/" RequestNavigate="OnGuideNavigate">vb-audio.com/Cable</Hyperlink>
                        <Run Text="."/>
                    </TextBlock>
                    <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#1F2937" FontSize="11.5"
                               Text="2. Run setup as administrator and restart Windows if needed."/>
                    <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#1F2937" FontSize="11.5"
                               Text="3. Select CABLE Input as the virtual cable output in MicMixer."/>
                    <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#1F2937" FontSize="11.5"
                               Text="4. In your voice chat, game, or streaming app, select CABLE Output as the microphone."/>
                    <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#1F2937" FontSize="11.5"
                               Text="5. Music: if the receiving app has noise suppression enabled, it may reduce the music — disable noise suppression there for the best sound."/>
                </StackPanel>
            </Border>
        </Expander>

        <!-- Project and contributor footer -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="12,8"
                Background="#E8EDF3" BorderBrush="#D7DEE7" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontSize="11.5" Foreground="#526173" TextWrapping="Wrap">
                    <Run Text="Like MicMixer? Consider gifting a subscription to "/>
                    <Hyperlink NavigateUri="https://www.twitch.tv/pixlexi"
                               RequestNavigate="OnGuideNavigate"
                               Foreground="#7C3AED" FontWeight="SemiBold">Pixlexi</Hyperlink><Run Text=" on Twitch."/>
                </TextBlock>
                <Button Grid.Column="1" Margin="14,0,0,0" Padding="10,4"
                        Click="OnAboutClick" Content="More information"
                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Background="#F8FAFC" Foreground="#334155"
                        BorderBrush="#C9D2DD" BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>
