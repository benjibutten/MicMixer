<Window x:Class="MicMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:MicMixer.UI"
        Title="MicMixer" Height="690" Width="1100" MinHeight="540" MinWidth="600"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        SizeChanged="OnWindowSizeChanged"
        Background="#F3F5F7"
        PreviewKeyDown="OnPreviewHotkeyKeyDown"
        PreviewMouseDown="OnPreviewHotkeyMouseDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <!-- Mic icon (clean cardioid mic outline) -->
        <Geometry x:Key="MicIcon">M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z</Geometry>
        <!-- Waveform / modded mic icon -->
        <Geometry x:Key="ModdedMicIcon">M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19M3,9H1V15H3V9M21,9H23V15H21V9</Geometry>
